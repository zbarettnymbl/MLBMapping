# MapForge Environment Variables
# Copy this file to .env and fill in values

# ---------- Database ----------
POSTGRES_DB=mapforge
POSTGRES_USER=mapforge
POSTGRES_PASSWORD=mapforge_dev
DATABASE_URL=postgresql://mapforge:mapforge_dev@localhost:5432/mapforge

# ---------- Server ----------
NODE_ENV=development
PORT=3001
JWT_SECRET=dev-secret-change-in-production
SESSION_SECRET=change-this-to-a-random-secret
CORS_ORIGIN=http://localhost:5173

# ---------- Redis (optional for local dev) ----------
REDIS_URL=

# ---------- Google OAuth (for SSO) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ---------- Credential Encryption ----------
# 32-byte hex key for AES-256-GCM encryption of stored credentials
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# ---------- BigQuery ----------
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY_PATH=

# ---------- Client ----------
VITE_API_URL=http://localhost:3001
