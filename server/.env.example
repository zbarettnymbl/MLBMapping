# MapForge Server Environment Variables
# Copy this file to .env and fill in values

DATABASE_URL=postgresql://mapforge:mapforge_dev@localhost:5432/mapforge
NODE_ENV=development
PORT=3001
SESSION_SECRET=change-this-to-a-random-secret
CORS_ORIGIN=http://localhost:5173

# Redis (optional for local dev)
REDIS_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# BigQuery
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY_PATH=

# Mock BigQuery (dev only) - set to 'true' to enable mock data without GCP credentials
MOCK_BIGQUERY=false
